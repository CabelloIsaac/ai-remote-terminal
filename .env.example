# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram numeric user ID (get from @userinfobot)
AUTHORIZED_USER_ID=your_user_id_here

# Claude CLI command (default: claude)
CLAUDE_COMMAND=claude

# Output streaming mode: "batched" | "streaming"
# batched = 1 merged message per interval (cleaner)
# streaming = send as fast as Telegram allows (more real-time)
OUTPUT_MODE=batched

# Batch interval in ms (only applies in batched mode)
BATCH_INTERVAL_MS=2000

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
